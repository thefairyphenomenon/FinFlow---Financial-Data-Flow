# DataFlow Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Database
POSTGRES_USER=dataflow_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=dataflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Free API Keys (get these for free)
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (optional, 25 req/day free)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://dataflow_user:your_secure_password_here@localhost:5432/airflow_db
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_for_jwt_here
